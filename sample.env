# Security
# Set to True for development, False for production
DEBUG=True
SECRET_KEY=generate-a-secure-secret-key-here

# Database Configuration
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your-password
DB_HOST=localhost
DB_PORT=5432
# DB_SSLMODE=require # Uncomment for Supabase/Production

# Networking (Production)
# Comma-separated lists
# ALLOWED_HOSTS=your-domain.com,another-domain.com
# CORS_ALLOWED_ORIGINS=https://your-frontend.com
# CSRF_TRUSTED_ORIGINS=https://your-frontend.com

# Cookie Configuration (Production)
# SESSION_COOKIE_DOMAIN=.your-domain.com
# CSRF_COOKIE_DOMAIN=.your-domain.com
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True